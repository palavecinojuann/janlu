rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Las fotos de los productos pueden ser vistas por todos, pero solo subidas por usuarios logueados
    match /products/{allPaths=**} {
      allow read: if true; 
      allow write: if request.auth != null; 
    }
    // Cualquier otro archivo requiere autenticación
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
